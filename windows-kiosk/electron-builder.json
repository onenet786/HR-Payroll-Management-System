{
  "appId": "com.binishaq.hrsuite.kiosk",
  "productName": "Bin Ishaq Attendance Kiosk",
  "extraMetadata": {
    "main": "windows-kiosk/main.cjs"
  },
  "directories": {
    "output": "dist-kiosk"
  },
  "files": [
    "windows-kiosk/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "windows-kiosk/bridge-bin",
      "to": "uru4500-bridge",
      "filter": [
        "URU4500Bridge.exe",
        "DPUruNet.dll",
        "dpfj.dll",
        "dpfpdd.dll",
        "dpfpdd_4k.dll",
        "SecuGen.FDxSDKPro.Windows.dll",
        "sgfplib.dll"
      ]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  }
}
